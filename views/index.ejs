<% currentPage = 'home' %>
<%- include('partials/header') %>

<!-- HERO -->
<section class="hero-section">
  <div class="container position-relative h-100">
    <div class="row h-100 align-items-center">
      <div class="col-lg-7">
        <span class="hero-badge"> Fresquinho todo dia</span>
        <h1 class="hero-title">
          O sabor que<br/>
          <span class="text-highlight">aquece</span> sua manhã
        </h1>
        <p class="hero-subtitle">
          Pães artesanais, doces irresistíveis e o melhor café da cidade.
          Feito com amor e ingredientes selecionados.
        </p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/lanches" class="btn btn-hero-primary">
            <i class="bi bi-bag-fill me-2"></i>Ver Cardápio
          </a>
          <a href="/coffee-break" class="btn btn-hero-secondary">
            <i class="bi bi-cup-hot-fill me-2"></i>Coffee Break
          </a>
        </div>
      </div>
      <div class="col-lg-5 text-center d-none d-lg-block">
        <img src="/img/logo/memorias.png" alt="Empório dos Pães" class="hero-logo" />
      </div>
    </div>
  </div>
</section>




<section class="section-sobre py-6">
  <div class="container">
    <div class="row align-items-center g-5 mb-6">
      <div class="col-lg-6">
        <span class="section-badge"> Sobre a Empório</span>
        <h2 class="section-title mt-2">Uma história feita de sabor e carinho</h2>
        <p class="sobre-text">
          Desde novembro de 2011 a Empório dos Pães alimenta a paixão dos seus clientes por bolos,
          doces, pães, salgados, sopas, saladas, cafés gelados e sobremesas especiais preparados
          de forma artesanal.
        </p>
        <p class="sobre-text">
          Nos tornamos um excelente lugar para satisfazer todos os seus desejos gastronômicos,
          desde passar o tempo tomando um café gourmet enquanto lê um jornal, um almoço entre
          amigos, até momentos especiais com a família, negócios ou simples a dois.
          Um espaço aconchegante e convidativo, com diversas delícias artesanais.
        </p>
        <p class="sobre-text">
          A padaria Empório dos Pães se orgulha da missão de ser e fazer diferente, de tratar
          de forma especial não somente os clientes, mas também seus colaboradores e fornecedores,
          sempre com respeito e honra aos seus compromissos. Procuramos sempre inovar, com a
          preocupação constante de fazer delícias de encher os olhos e a boca.
        </p>
      </div>
      <div class="col-lg-6">
        <div class="sobre-img-wrap">
          <img src="/img/home/sobre.png" alt="Sabor que cria memórias" class="sobre-img" />
        </div>
      </div>
    </div>

    
    <hr class="sobre-divider my-5" />

   
    <div class="row align-items-center g-5">
      <div class="col-lg-6 order-lg-2">
        <span class="section-badge">📍 Unidade Pariquera-Açu</span>
        <h2 class="section-title mt-2">Agora também em Pariquera-Açu</h2>
        <p class="sobre-text">
          A nossa unidade em Pariquera-Açu já está de portas abertas e está sendo um sucesso!
          Montamos um cardápio super especial para você aproveitar em um ambiente bem aconchegante.
        </p>
        <div class="row g-3 mt-1">
          <div class="col-sm-6">
            <div class="unidade-card">
              <i class="bi bi-geo-alt-fill text-warning me-2"></i>
              <div>
                <strong class="d-block">Registro</strong>
                <small class="text-muted">Av. Clara Gianotti de Souza, 304 – Centro</small><br/>
                <small class="text-muted">(13) 3821-5366 | 99708-1804</small>
              </div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="unidade-card">
              <i class="bi bi-geo-alt-fill text-warning me-2"></i>
              <div>
                <strong class="d-block">Pariquera-Açu</strong>
                <small class="text-muted">R. Ferrúcio Padovan, 24 – Centro</small><br/>
                <small class="text-muted">(13) 99100-6866</small>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-3">
          <span class="horario-badge"><i class="bi bi-clock me-1"></i>Seg-Dom: 06h00 às 21h30</span>
        </div>
      </div>
      <div class="col-lg-6 order-lg-1">
        <div class="sobre-img-wrap">
          <img src="/img/home/loja2.png" alt="Loja de Pariquera" class="sobre-img" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CARROSSEL -->
<section class="section-carousel py-0">
  <div id="carouselHome" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
    <div class="carousel-indicators">
      <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="0" class="active"></button>
      <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="1"></button>
    </div>
    <div class="carousel-inner">
      <div class="carousel-item active">
        <img src="/img/home/delivery.jpg" class="d-block w-100 carousel-img" alt="Delivery Empório dos Pães" />
        <div class="carousel-caption carousel-caption-custom">
          <h3>Delivery de Confiança</h3>
          <p>Peça do conforto da sua casa – das 08h às 21h30</p>
          <a href="https://wa.me/5513988093870" target="_blank" class="btn btn-hero-primary btn-sm px-4">
            <i class="bi bi-whatsapp me-2"></i>Fazer Pedido
          </a>
        </div>
      </div>
      <div class="carousel-item">
        <img src="/img/home/memorias.png" class="d-block w-100 carousel-img" alt="Sabor que cria memórias" />
        <div class="carousel-caption carousel-caption-custom">
          <h3>Sabor que cria memórias</h3>
          <p>Duas unidades: Registro e Pariquera-Açu</p>
          <a href="/lanches" class="btn btn-hero-primary btn-sm px-4">
            <i class="bi bi-bag-fill me-2"></i>Ver Cardápio
          </a>
        </div>
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>
  </div>
</section>

<!-- ENCOMENDAS -->
<section class="section-encomendas py-6">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <span class="section-badge"> Encomendas</span>
        <h2 class="section-title mt-2">Feito especialmente para você</h2>
        <p class="sobre-text">
          Aceitamos encomendas para festas, aniversário, coffee break, eventos corporativos e muito mais.
        </p>
        <ul class="encomenda-lista list-unstyled">
          <li><i class="bi bi-check2-circle text-warning me-2"></i>Salgados feitos com massa de pão de batata</li>
          <li><i class="bi bi-check2-circle text-warning me-2"></i>A mais saborosa linha de bolos e tortas</li>
          <li><i class="bi bi-check2-circle text-warning me-2"></i>Produtos zero açúcar disponíveis</li>
          <li><i class="bi bi-check2-circle text-warning me-2"></i>Cestas de café da manhã, doces e pães</li>
          <li><i class="bi bi-check2-circle text-warning me-2"></i>Cestas personalizadas para datas comemorativas</li>
        </ul>
        <a href="https://wa.me/5513988093870" target="_blank" class="btn btn-hero-primary mt-3">
          <i class="bi bi-whatsapp me-2"></i>Fazer Encomenda
        </a>
      </div>
      <div class="col-lg-6 order-lg-1">
          <div class="sobre-img-wrap">
            <img src="/img/home/encomenda.png" alt="Loja de Pariquera" class="sobre-img" />
          </div>
        </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
